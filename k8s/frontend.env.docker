# frontend/.env.docker
# This file is used when building the Docker image locally.
# It tells the React app where the backend API is.
#
# For local docker-compose: use localhost
# For EKS: this gets overridden by the frontend-config ConfigMap
#
# VITE_ prefix is required by Vite (React build tool)
# to expose env vars to the browser
VITE_API_PATH="http://localhost:31100"
